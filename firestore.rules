rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSessionCreator(pin) {
      return isAuthenticated() &&
             request.auth.uid == get(/databases/$(database)/documents/sessions/$(pin)).data.creatorUid;
    }

    // Shared boards: public read, authenticated create, no edits/deletes
    match /shared_boards/{shareId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Game sessions
    match /sessions/{pin} {
      // Any authenticated user can read game state (students need this)
      allow read: if isAuthenticated();

      // Creator must set their own UID as creatorUid
      allow create: if isAuthenticated()
                    && request.resource.data.creatorUid == request.auth.uid
                    && request.resource.data.gameState == "lobby";

      // Only the session creator can update or delete the session
      allow update, delete: if isSessionCreator(pin);

      // Secret answers - only the session creator can read or write
      match /private/{docId} {
        allow read, write: if isSessionCreator(pin);
      }

      // Player documents
      match /players/{playerId} {
        // Any authenticated user in the session can read player data
        allow read: if isAuthenticated();

        // Players can create their own doc with valid initial state
        allow create: if isAuthenticated()
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.banned == false
                      && request.resource.data.teamId == null
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() <= 20;

        // Teacher can update anything; players can only update their own limited fields
        allow update: if isAuthenticated() && (
          // Teacher: full access
          isSessionCreator(pin) ||
          // Player: own doc, only lastActive and answers
          (request.auth.uid == resource.data.uid &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastActive', 'answers']) &&
           // Prevent changing uid, name, teamId, banned via merge
           request.resource.data.uid == resource.data.uid &&
           request.resource.data.name == resource.data.name &&
           request.resource.data.teamId == resource.data.teamId &&
           request.resource.data.banned == resource.data.banned)
        );

        // Only teacher can delete player docs
        allow delete: if isSessionCreator(pin);
      }
    }
  }
}
